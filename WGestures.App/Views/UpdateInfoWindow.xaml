<Window x:Class="WGestures.App.Views.UpdateInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WGestures.App.Views"
        mc:Ignorable="d"
        Title="新版本可用"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        Background="White"
        FontFamily="Microsoft YaHei"
        FontSize="12"
       
        >

    <StackPanel Orientation="Vertical" Margin="20,20,20,15">
        <!-- FlowLayoutPanel 1: 标题与下载链接 -->
        <WrapPanel Margin="0,0,0,16">
            <TextBlock x:Name="label1"
                       Text="WGestures发布了新版本！"
                       FontSize="19"
                       VerticalAlignment="Center" />
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                <Hyperlink x:Name="lnk_gotoUrl"
                           FontSize="19"
                           Click="lnk_gotoUrl_Click"
                           TextDecorations="Underline">
                    前往下载
                </Hyperlink>
            </TextBlock>
        </WrapPanel>

        <!-- FlowLayoutPanel 2: 版本信息 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,17">
            <TextBlock x:Name="label3" Text="当前版本:" VerticalAlignment="Center" />
            <TextBlock x:Name="lb_currentVersion" Text="x.x.x.x" Foreground="Gray" Margin="8,0,16,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="label5" Text="新版本:" VerticalAlignment="Center" />
            <TextBlock x:Name="lb_newVersion" Text="y.y.y.y" Foreground="DeepSkyBlue" Margin="8,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- FlowLayoutPanel 3: 更新内容文本框 -->
        <StackPanel Orientation="Vertical" Margin="0,0,0,9">
            <TextBlock x:Name="label2" Text="主要更新内容:" Margin="0,0,0,4" />
            <TextBox x:Name="tb_whatsNew"
                     Width="425"
                     Height="178"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Microsoft YaHei"
                     FontSize="12" />
        </StackPanel>

        <!-- 确认/关闭 按钮 -->
        <Button x:Name="btn_ok"
                Content="关闭"
                Width="165"
                Height="29"
                HorizontalAlignment="Center"
                Margin="0,0,0,10"
                Click="btn_ok_Click" />
    </StackPanel>
</Window>